{
  "name": "wallpaper-app",
  "version": "1.0.4",
  "description": "A Windows background application that automatically syncs wallpapers.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "publish": "electron-builder --win --publish always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Debanjan110d/wallpaper-sync-app.git"
  },
  "build": {
  "appId": "com.wallpaper.syncapp",
  "productName": "Wallpaper Sync App",
  "win": {
    "target": "nsis",
    "icon": "icon.png"
  },
  "extraResources": [
    "wall_img/**/*"
  ],
  "publish": [
    {
      "provider": "github"
    }
  ]
},
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "latest",
    "wallpaper": "latest"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^26.8.1"
  }
}
