{
  "name": "wallpaper-app",
  "version": "1.0.5",
  "description": "A Windows background application that automatically syncs wallpapers.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "publish": "electron-builder --win --publish always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Debanjan110d/wallpaper-sync-app.git"
  },
  "build": {
    "appId": "com.wallpaper.syncapp",
    "productName": "Wallpaper Sync App",
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "asar": false,
    "extraResources": [
      {
        "from": "wall_img",
        "to": "wall_img",
        "filter": ["**/*"]
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "latest",
    "wallpaper": "latest"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^26.8.1"
  }
}
